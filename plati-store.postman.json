                  "",
                  "pm.test(`Receive products by selected price range ${priceMin}-${priceMax}`, function () {",
                  "    const productList = pm.response.json();",
                  "    // console.log(productList)",
                  "    for (const product of productList) {",
                  "        pm.expect(product.price).to.be.at.least(priceMin);",
                  "        pm.expect(product.price).to.be.at.most(priceMax);",
