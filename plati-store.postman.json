        {
          "name": "deleteUser",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "    url: pm.collectionVariables.get('baseUrl') + \"/api/v1/users/\",",
                  "    method: 'POST',",
                  "    header: {",
                  "        'Content-Type': 'application/json'",
                  "    },",
                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({",
                  "            \"name\": \"Cool Man\",",
                  "            \"email\": \"nico@gmail.com\",",
                  "            \"password\": \"1234q\",",
                  "            \"avatar\": \"https://picsum.photos/800/131/sdasd/ad\"",
                  "        })",
                  "    }",
                  "}, function (err, response) {",
                  "    if (err) {",
                  "        console.log(err);",
                  "    }",
                  "    const json = response.json()",
                  "    pm.test(\"User is created\", function () {",
                  "        pm.expect(response).to.have.property('code', 201);",
                  "    })",
                  "    pm.collectionVariables.set(\"createdUserId\", json.id)",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const userId = pm.collectionVariables.get(\"createdUserId\");",
                  "",
                  "pm.sendRequest({",
                  "    url: pm.collectionVariables.get(\"baseUrl\") + `/api/v1/users/${userId}`,",
                  "    method: \"GET\",",
                  "    header: {",
                  "        'Content-Type': 'application/json'",
                  "    }",
                  "}, function (err, response) {",
                  "    pm.expect(err).to.equal(null);",
                  "    const getUserJson = response.json();",
                  "    ",
                  "    pm.test(\"Get created user\", function () {",
                  "        pm.expect(response.code).to.eql(400)",
                  "        pm.expect(getUserJson.message).to.include('Could not find any entity of type \"User\" matching')",
                  "    })",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
