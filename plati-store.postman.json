    {
      "name": "Users",
      "item": [
        {
          "name": "createUser",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "})",
                  "pm.test(\"Status text is 'Created'\", function () {",
                  "    pm.response.to.have.status('Created')",
                  "})",
                  "",
                  "const requestBody = JSON.parse(pm.request.body.raw);",
                  "const json = pm.response.json()",
                  "pm.test(\"All major user fields are returned\", function () {",
                  "    pm.expect(json).to.have.property('id')",
                  "    pm.expect(json.email).to.include('nico@gmail.com')",
                  "    pm.expect(json.password).to.include('1234q')",
                  "    pm.expect(json.name).to.include('Cool Man')",
                  "    pm.expect(json.role).to.include('customer')",
                  "    pm.expect(json.avatar).to.include('https://picsum.photos/800/131/sdasd/ad')",
                  "})",
                  "",
                  "pm.sendRequest({",
                  "    url: pm.collectionVariables.get(\"baseUrl\") + `/api/v1/users/${json.id}`,",
                  "    method: \"GET\",",
                  "    header: {",
                  "        'Content-Type': 'application/json'",
                  "    }",
                  "}, function (err, response) {",
                  "    pm.expect(err).to.equal(null);",
                  "    const getUserJson = response.json();",
                  "",
                  "    pm.test(\"Get created user\", function () {",
                  "        pm.expect(response.code).to.eql(200)",
                  "        pm.expect(getUserJson.email).to.eql(requestBody.email)",
                  "        pm.expect(getUserJson.password).to.eql(requestBody.password)",
                  "        pm.expect(getUserJson.name).to.eql(requestBody.name)",
                  "        pm.expect(getUserJson.id).to.eql(json.id)",
                  "    })",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [""],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
